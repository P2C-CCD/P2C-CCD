      "dataset": {
        "kind": "tight_inclusion_reference"
      }
    },
    {
      "name": "scalable_ccd_sample_rt_exact_vf",
      "method": "RTExact",
      "dataset": {
        "kind": "scalable_ccd_sample",
        "family": "vf",
        "limit": 64
      },
      "config": {
        "backend_name": "cpu_reference_rt"
      }
    },
    {
      "name": "rigid_ipc_body_pairs_rt_exact",
      "method": "RTExact",
      "dataset": {
        "kind": "rigid_ipc",
        "family": "vf",
        "dimension": "3D",
        "limit": 64,
        "include_fixed_fixed_pairs": false
      },
      "config": {
        "backend_name": "cpu_reference_rt"
      }
    }
  ]
}
