{
  "schema_version": 1,
  "suite_name": "correctness_external_smoke",
  "suite_type": "correctness",
  "seed": 19,
  "output_root": "src/outputs/benchmark_suites",
  "notes": "External correctness suite for first-layer reference stacks. Tight Inclusion is checked as a reference implementation; Scalable CCD sample and Rigid-IPC provide imported query batches when local data is available.",
  "cases": [
    {
      "name": "tight_inclusion_reference_available",
