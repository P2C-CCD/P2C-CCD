{
  "schema_version": 1,
  "suite_name": "learned_style_comparison_smoke",
  "suite_type": "performance",
  "seed": 67,
  "output_root": "src/outputs/benchmark_suites",
  "notes": "NeuralSVCD-style continuous surrogate and CabiNet-style pose-level surrogate comparison. These are style baselines, not certified CCD replacements.",
  "cases": [
    {
      "name": "neural_svcd_style_safe",
      "method": "NeuralSVCDStyle",
      "dataset": {
        "kind": "internal_generated",
        "mesh_count_per_split": 3,
        "robot_link_count": 1,
        "include_robot_links": true
      },
      "config": {
        "time_sample_count": 9,
        "collision_threshold": 0.5,
        "uncertainty_fallback_threshold": 0.35,
        "conservative_fallback": true,
        "fallback_on_ood": true
      }
    },
    {
      "name": "cabinet_style_pose_level",
      "method": "CabiNetStyle",
      "dataset": {
        "kind": "internal_generated",
        "mesh_count_per_split": 3,
        "robot_link_count": 1,
        "include_robot_links": true
      },
      "config": {
        "pose_sample_count": 2,
        "collision_threshold": 0.5,
        "conservative_fallback": false,
        "fallback_on_ood": false
      }
    },
    {
      "name": "cabinet_style_multi_pose",
      "method": "CabiNetStyle",
      "dataset": {
        "kind": "internal_generated",
        "mesh_count_per_split": 3,
        "robot_link_count": 1,
        "include_robot_links": true
      },
      "config": {
        "pose_sample_count": 5,
        "collision_threshold": 0.5,
        "conservative_fallback": true,
        "uncertainty_fallback_threshold": 0.35
      }
    }
  ]
}
