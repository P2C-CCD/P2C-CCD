    {
      "name": "bvh_exact_internal",
      "method": "BVHExact",
      "dataset": {
        "kind": "internal_generated",
        "mesh_count_per_split": 2,
        "robot_link_count": 1,
        "include_robot_links": true
      },
      "config": {
        "backend_name": "cpu_aabb_sort_sweep"
      }
    },
    {
      "name": "rt_exact_internal",
      "method": "RTExact",
      "dataset": {
        "kind": "internal_generated",
        "mesh_count_per_split": 2,
        "robot_link_count": 1,
        "include_robot_links": true
      },
      "config": {
        "backend_name": "cpu_reference_rt"
      }
    }
  ]
}
