{
  "schema_version": 1,
  "suite_name": "ablation_smoke",
  "suite_type": "ablation",
  "seed": 31,
  "output_root": "src/outputs/benchmark_suites",
  "notes": "Patch granularity, slab count, proxy family, and STPF-head smoke ablations.",
  "cases": [
    {
      "name": "patch_granularity",
      "method": "PatchGranularityAblation",
      "dataset": {
        "kind": "internal_generated",
        "mesh_count_per_split": 2,
        "robot_link_count": 1,
        "include_robot_links": true
      },
      "config": {
        "options": [
          {"name": "coarse_1x", "patches_per_object": 1, "radius_scale": 1.0, "offset_scale": 0.0},
          {"name": "medium_2x", "patches_per_object": 2, "radius_scale": 1.0, "offset_scale": 0.0},
          {"name": "fine_4x", "patches_per_object": 4, "radius_scale": 1.0, "offset_scale": 0.0}
        ]
      }
    },
    {
      "name": "slab_proxy",
      "method": "SlabProxyAblation",
      "dataset": {
        "kind": "internal_generated",
        "mesh_count_per_split": 2,
        "robot_link_count": 1,
        "include_robot_links": true
      },
      "config": {
        "options": [
          {"name": "slab1_aabb", "slab_count": 1, "proxy_type_a": "SWEPT_AABB", "proxy_type_b": "SWEPT_AABB"},
          {"name": "slab2_aabb", "slab_count": 2, "proxy_type_a": "SWEPT_AABB", "proxy_type_b": "SWEPT_AABB"},
          {"name": "slab4_capsule", "slab_count": 4, "proxy_type_a": "CAPSULE", "proxy_type_b": "CAPSULE"}
        ]
      }
    },
    {
      "name": "no_proposal",
      "method": "NoProposal",
      "dataset": {
        "kind": "internal_generated",
        "mesh_count_per_split": 2,
        "robot_link_count": 1,
        "include_robot_links": true
      }
    },
    {
      "name": "interval_only",
      "method": "IntervalOnly",
      "dataset": {
        "kind": "internal_generated",
        "mesh_count_per_split": 2,
        "robot_link_count": 1,
        "include_robot_links": true
      }
    },
    {
      "name": "ranking_only",
      "method": "RankingOnly",
      "dataset": {
        "kind": "internal_generated",
        "mesh_count_per_split": 2,
        "robot_link_count": 1,
        "include_robot_links": true
      }
    },
    {
      "name": "no_queue_decouple",
      "method": "NoQueueDecouple",
      "config": {
        "candidate_count": 1024,
        "repeat_count": 3,
        "warmup_count": 1,
        "batch_size": 512,
        "seed": 31
      }
    }
  ]
}
